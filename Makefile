# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  ImGui_config = debug
  saffron_engine_2d_config = debug
  slimes_config = debug

else ifeq ($(config),release)
  ImGui_config = release
  saffron_engine_2d_config = release
  slimes_config = release

else ifeq ($(config),dist)
  ImGui_config = dist
  saffron_engine_2d_config = dist
  slimes_config = dist

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := ImGui saffron-engine-2d slimes

.PHONY: all clean help $(PROJECTS) Engine Engine/deps

all: $(PROJECTS)

Engine: Engine/deps saffron-engine-2d

Engine/deps: ImGui

ImGui:
ifneq (,$(ImGui_config))
	@echo "==== Building ImGui ($(ImGui_config)) ===="
	@${MAKE} --no-print-directory -C build -f ImGui.make config=$(ImGui_config)
endif

saffron-engine-2d: ImGui
ifneq (,$(saffron_engine_2d_config))
	@echo "==== Building saffron-engine-2d ($(saffron_engine_2d_config)) ===="
	@${MAKE} --no-print-directory -C build -f saffron-engine-2d.make config=$(saffron_engine_2d_config)
endif

slimes: saffron-engine-2d ImGui
ifneq (,$(slimes_config))
	@echo "==== Building slimes ($(slimes_config)) ===="
	@${MAKE} --no-print-directory -C build -f slimes.make config=$(slimes_config)
endif

clean:
	@${MAKE} --no-print-directory -C build -f ImGui.make clean
	@${MAKE} --no-print-directory -C build -f saffron-engine-2d.make clean
	@${MAKE} --no-print-directory -C build -f slimes.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug"
	@echo "  release"
	@echo "  dist"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   ImGui"
	@echo "   saffron-engine-2d"
	@echo "   slimes"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"